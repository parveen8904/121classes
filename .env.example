# --- Supabase (Phase 1) ---
# Create a project at https://supabase.com, then Project Settings → API:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server-only (Project Settings → API → service_role). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public site URL (used for auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Razorpay (Phase 5 payments) ---
# Razorpay Dashboard → Settings → API Keys. Use TEST keys first (rzp_test_…).
# The key id is safe in the browser; the secret is server-only.
# RAZORPAY_KEY_ID and NEXT_PUBLIC_RAZORPAY_KEY_ID hold the SAME value.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# --- Messaging (Phase 6) ---
# Email via Mailgun HTTP API (Mailgun → Sending → API keys). Domain e.g. 121coaching.ai
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=121coaching.ai
# NOTIFY_FROM_EMAIL=1:1 CA Classes <no-reply@121coaching.ai>
# WhatsApp via Interakt (needs pre-approved templates on their dashboard)
# INTERAKT_API_KEY=

# --- AI: Claude (Phase 7 — subjective grading + doubt-solving) ---
# console.anthropic.com → API keys. Optional model override.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Added in later phases (leave blank for now) ---
# RAZORPAY_WEBHOOK_SECRET=
# BUNNY_STREAM_LIBRARY_ID=
# BUNNY_STREAM_API_KEY=
# INTERAKT_API_KEY=
# RESEND_API_KEY=
# ANTHROPIC_API_KEY=
