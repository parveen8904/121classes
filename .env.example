# --- Supabase (Phase 1) ---
# Create a project at https://supabase.com, then Project Settings → API:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server-only (Project Settings → API → service_role). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public site URL (used for auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Added in later phases (leave blank for now) ---
